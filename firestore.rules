rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function role() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return signedIn() && role() == 'admin';
    }

    function canWriteBusiness() {
      return signedIn() && (role() == 'admin' || role() == 'operador');
    }

    match /users/{uid} {
      // Permite resolver usuario interno por username en login (query de 1 documento)
      allow list: if !signedIn() && request.query.limit != null && request.query.limit <= 1;

      // Usuario autenticado: puede leer su propio perfil
      allow get: if isSelf(uid) || isAdmin();

      // Solo admin administra perfiles internos
      allow create, update, delete: if isAdmin();
    }

    match /cirugias/{docId} {
      allow read: if signedIn();
      allow create, update: if canWriteBusiness();
      allow delete: if isAdmin();
    }

    match /audit_log/{auditId} {
      allow create: if canWriteBusiness();
      allow read: if isAdmin();
      allow update, delete: if false;
    }
  }
}
