rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function userRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    function canWrite() { return signedIn() && (userRole() == 'admin' || userRole() == 'operador'); }

    match /users/{uid} {
      allow read: if signedIn() && request.auth.uid == uid;
      allow write: if signedIn() && userRole() == 'admin';
    }

    match /surgeries/{docId} {
      allow read: if signedIn();
      allow create, update: if canWrite();
      allow delete: if signedIn() && userRole() == 'admin';
    }

    match /audit_log/{logId} {
      allow create: if canWrite();
      allow read: if signedIn() && userRole() == 'admin';
      allow update, delete: if false;
    }
  }
}
